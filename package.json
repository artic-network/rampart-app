{
  "name": "artic-rampart",
  "version": "1.2.1",
  "author": "James Hadfield, Ainé O'Toole, ARTIC network, Nick Loman, Andrew Rambaut",
  "main": "src/electron.js",
  "bin": {
    "rampart": "./rampart.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artic-network/rampart-app.git"
  },
  "private": false,
  "license": "AGPL-3.0-only",
  "homepage": ".",
  "dependencies": {
    "chalk": "^2.4.1",
    "chokidar": "^3.3.1",
    "collections": "^2.0.3",
    "cors": "^2.8.4",
    "csvtojson": "^1.1.9",
    "d3-array": "1.2.4",
    "d3-axis": "^1.0.8",
    "d3-color": "^1.2.0",
    "d3-dsv": "^1.1.1",
    "d3-interpolate": "^1.2.0",
    "d3-scale": "^2.0.0",
    "d3-scale-chromatic": "^1.3.3",
    "d3-selection": "^1.3.0",
    "d3-shape": "^1.2.0",
    "eslint-plugin-import": "^2.17.2",
    "express": "^4.16.3",
    "js-yaml": "^3.13.1",
    "lodash": "^4.17.15",
    "prop-types": "^15.7.2",
    "rc-slider": "^8.7.1",
    "react": "^16.8.6",
    "react-color": "^2.17.3",
    "react-contextmenu": "^2.11.0",
    "react-dom": "^16.8.6",
    "react-icons": "^3.6.1",
    "react-scripts": "^3.3.0",
    "react-select": "2.4.2",
    "socket.io": "2.2.0",
    "socket.io-client": "^2.2.0",
    "styled-components": "^5.0.1",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "scripts": {
    "start": "NODE_OPTIONS=--openssl-legacy-provider react-scripts start",
    "build": "NODE_OPTIONS=--openssl-legacy-provider react-scripts build",
    "server": "node src/server.js",
    "test": "NODE_OPTIONS=--openssl-legacy-provider react-scripts test --env=jsdom",
    "eject": "react-scripts eject",
    "electron": "electron .",
    "electron-dev": "NODE_ENV=development electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:all": "npm run build && electron-builder --mac --win"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "description": "Read Assignment, Mapping, and Phylogenetic Analysis in Real Time.",
  "bugs": {
    "url": "https://github.com/artic-network/rampart-app/issues"
  },
  "keywords": [],
  "build": {
    "appId": "network.artic.rampart",
    "productName": "RAMPART",
    "files": [
      "build/**/*",
      "server/**/*",
      "src/electron.js",
      "src/preload.js",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/bin/${os}",
        "to": "resources/bin/${os}",
        "filter": ["**/*"]
      }
    ],
    "asarUnpack": [
      "resources/**/*",
      "build/**/*",
      "server/pipelines/**/*"
    ],
    "directories": {
      "buildResources": "public"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "notarize": true
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "extraResources": [
        {
          "from": "resources/python/win32",
          "to": "resources/python/win32",
          "filter": ["**/*"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Science"
    },
    "extraMetadata": {
      "main": "src/electron.js"
    }
  }
}
