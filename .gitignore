# dependencies
/node_modules

# testing
/coverage

# production
/build

# misc
**.DS_Store
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*

real_time_reads/
datasets/
coordinate_reference.fasta

#don't commit demuxed or annotated reads...
demuxed/
annotations/
binned*

# editor configs etc
*.code-workspace
*.iml
*.iws
*.ipr
.vscode/

# folder with temporary run-specific data
/tmp/

# snakemake stuff
.snakemake/

# electron-builder output
/dist
/dist_electron
*.dmg
*.exe
*.AppImage
*.deb
*.rpm
*.zip

# example data and protocols (keep in repo but ignore user-generated examples)
/example_data/*/fastq
/example_data/*/annotations
/example_data/*/demuxed

# bundled resources (platform-specific binaries downloaded during build setup)
/resources/bin/win32/minimap2.exe
/resources/bin/linux/minimap2
/resources/python/win32/python.exe
/resources/python/win32/*.dll
/resources/python/win32/*.zip
/resources/python/win32/Scripts/
/resources/python/win32/Lib/
